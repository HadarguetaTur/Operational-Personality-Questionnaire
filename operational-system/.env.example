# ============================================================
# Operational Mailing & Funnel System - Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values.

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- App ----
# Production: your public site URL without trailing slash (required for OG URLs, sitemap, links).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Analytics (GA4) ----
# Measurement ID (e.g. G-XXXXXXXXXX). Omit in dev if you do not want GA calls.
# NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# The questionnaire lives at /quiz on this same app (no separate QUIZ_URL).

# ---- Admin ----
# Comma-separated list of admin email addresses (bootstrap admins)
# Additional admins are added via the invitation flow at /admin/users.
# WARNING: if this list is empty, admin access is BLOCKED for everyone.
ADMIN_EMAILS=admin@yourdomain.com
#
# RLS (e.g. dashboard read of landing_events): Next.js uses ADMIN_EMAILS above, but Postgres
# uses public.is_admin(). For emails listed only here (without user_metadata.role = admin),
# mirror the same comma-separated list into Supabase:
#   ALTER DATABASE postgres SET app.admin_emails TO 'admin@yourdomain.com,other@yourdomain.com';
# Or run migration 008_is_admin_alignment.sql then set app.admin_emails as needed.
ADMIN_NOTIFICATION_EMAIL=your-personal@gmail.com

# Optional: where landing "contact" form notifications are sent (defaults to ADMIN_NOTIFICATION_EMAIL, then first ADMIN_EMAILS)
# CONTACT_FORM_TO_EMAIL=notifications@yourdomain.com

# Number of days an admin invitation remains valid (default: 7)
INVITE_TOKEN_TTL_DAYS=7

# ---- Google Workspace (Gmail + Drive) ----
# OAuth2 credentials from Google Cloud Console
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REFRESH_TOKEN=your-refresh-token

# Gmail sender address (the authenticated Google Workspace email)
GMAIL_SENDER_ADDRESS=you@yourdomain.com

# ---- Storage (Supabase) ----
# Bucket `documents` should be PRIVATE. Admins open uploads via POST /api/admin/documents/sign-url.
# See supabase/STORAGE_DOCUMENTS.md

# Google Drive base folder ID (where lead folders are created)
GOOGLE_DRIVE_BASE_FOLDER_ID=your-folder-id

# Alternative: Service Account for domain-wide delegation
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}
# GOOGLE_DELEGATED_USER=admin@yourdomain.com

# ---- Sumit (Payments) ----
# REQUIRED in production: reject webhooks if unset (forged payment / follow-up access).
SUMIT_WEBHOOK_SECRET=your-sumit-webhook-secret

# Optional: header `x-report-send-secret` must match for non-admin calls to /api/email/send-report
# REPORT_SEND_SECRET=long-random-secret

# Payment page URL for landing page CTAs
NEXT_PUBLIC_PAYMENT_URL=https://sumit.co.il/your-payment-page

# ---- Cloudflare Turnstile (bot protection for public forms) ----
# Create a widget at https://dash.cloudflare.com/?to=/:account/turnstile
# Use Cloudflare test keys for local dev: https://developers.cloudflare.com/turnstile/troubleshooting/testing/
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAADLBYRb5ZrM5K3zq
TURNSTILE_SECRET_KEY=0x4AAAAAADLBYWV7W-Fig4w1Pcxm1IT8qJc

# ---- Cal.com (Meeting Scheduling) ----
NEXT_PUBLIC_CALCOM_URL=https://cal.com/yourusername/session
CALCOM_URL=https://cal.com/yourusername/session
# Used by ManyChat bot when action=book_meeting.
# Should point to the FREE 15-min intro call event type (no payment required).
# The paid 350₪ characterization session is the follow-up step explained on the call.
CALCOM_BOOKING_URL=https://cal.com/yourusername/free-intro-15min

# ---- Bot ops ----
# OpenRouter API key — required for all LLM calls (classifier + writer)
# Get from: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Slack incoming webhook for human_handoff alerts (optional but recommended)
# Create at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx

# Vercel Cron auth for /api/cron/silent-leads — REQUIRED for cron to work
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Then set this exact value in Vercel Environment Variables too.
CRON_SECRET=long-random-secret

# Calendly webhook verification (optional MVP)
# CALENDLY_WEBHOOK_SECRET=your-calendly-secret

# ---- WhatsApp / SMS ----
# Option A: Twilio
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# TWILIO_FROM_NUMBER=+1234567890  # For SMS instead of WhatsApp

# Option B: Green API (alternative to Twilio)
# GREEN_API_INSTANCE=your-instance-id
# GREEN_API_TOKEN=your-api-token

# ---- ManyChat (WhatsApp AI Lead Warming) ----
# Shared secret sent as X-Webhook-Secret header in ManyChat External Requests.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MANYCHAT_WEBHOOK_SECRET=your-manychat-webhook-secret

# ManyChat API token — from ManyChat Dashboard → Settings → API
# Server-only: never prefix with NEXT_PUBLIC_
MANYCHAT_API_TOKEN=your-manychat-api-token

# Flow namespace for the "Bot Reply Sender" flow (single step: Send WhatsApp Message {{response}})
# Get it from: GET https://api.manychat.com/fb/page/getFlows — copy the `ns` of "Bot Reply Sender"
MANYCHAT_SEND_FLOW_NS=content20XXXXXXXXX

# Supabase – העתק ל-.env ומלא ערכים אמיתיים
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Base URL of this Vite app (quiz host). Used for OG image URLs in index.html and public links.
# Production example (no trailing slash): https://quiz.automateyourbiznow.com
# The Next.js site URL is separate — see operational-system/.env.example (NEXT_PUBLIC_APP_URL).
VITE_PUBLIC_APP_URL=

# Payment URL – קישור לדף תשלום (סאמיט)
VITE_PAYMENT_URL=https://pay.sumit.co.il/...

# אופציונלי – רק אם יש backend שמתחבר ל-DB ישירות
SUPABASE_DB_PASSWORD=

# Make – לשימוש ב-Edge Function trigger-send-report (הגדר ב-Supabase: Secrets)
# MAKE_API_KEY, MAKE_ORG_ID, MAKE_ZONE (אופציונלי, ברירת מחדל eu2.make.com)
# MAKE_SEND_REPORT_SCENARIO_ID (אופציונלי – אם לא מוגדר, מחפש סנריו בשם send_report)
